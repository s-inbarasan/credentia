{
  "entities": {
    "UserDocument": {
      "title": "UserDocument",
      "description": "Unified user profile information, stats, and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "name": { "type": "string", "description": "Display name" },
        "email": { "type": "string", "description": "User's email address" },
        "xp": { "type": "number", "description": "Total XP points" },
        "level": { "type": "number", "description": "Current level" },
        "createdAt": { "type": "string", "description": "Account creation timestamp" },
        "profileImage": { "type": "string", "description": "Profile picture URL" },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "Array of badge IDs" },
        "completedTopics": { "type": "array", "items": { "type": "string" }, "description": "Array of completed topic IDs" },
        "quizScores": { "type": "object", "description": "Map of topicId to highest score" },
        "simulationScores": { "type": "object", "description": "Map of simulationId to highest score" },
        "stats": {
          "type": "object",
          "properties": {
            "aiQueries": { "type": "number" },
            "actionsTaken": { "type": "number" },
            "strongPasswords": { "type": "number" },
            "phishingDetected": { "type": "number" },
            "threatsAnalyzed": { "type": "number" },
            "toolsUsed": { "type": "array", "items": { "type": "string" } },
            "simulationsCompleted": { "type": "number" },
            "topicsCompleted": { "type": "number" },
            "quizzesPassed": { "type": "number" }
          }
        },
        "riskScore": { "type": "number", "description": "Current risk score" },
        "preferences": {
          "type": "object",
          "properties": {
            "darkMode": { "type": "boolean" },
            "highContrast": { "type": "boolean" },
            "notifications": { "type": "boolean" },
            "soundEffects": { "type": "boolean" },
            "hapticFeedback": { "type": "boolean" }
          }
        }
      },
      "required": ["uid", "name", "email", "xp", "level", "createdAt", "badges", "completedTopics", "stats", "riskScore", "preferences"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session with the AI assistant.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Session ID" },
        "title": { "type": "string", "description": "Session title" },
        "updatedAt": { "type": "string", "description": "Last update timestamp" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string", "enum": ["user", "ai"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "title", "updatedAt", "messages"]
    },
    "RecentActivity": {
      "title": "RecentActivity",
      "description": "A log of recent actions taken by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Activity ID" },
        "title": { "type": "string", "description": "Activity title" },
        "type": { "type": "string", "enum": ["topic", "quiz", "simulation", "tool"] },
        "timestamp": { "type": "string", "description": "Timestamp of the activity" }
      },
      "required": ["id", "title", "type", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserDocument" },
      "description": "Stores the user's unified profile, stats, and preferences."
    },
    "/users/{userId}/chatSessions/{sessionId}": {
      "schema": { "$ref": "#/entities/ChatSession" },
      "description": "Stores individual chat sessions for a user."
    },
    "/users/{userId}/recentActivity/{activityId}": {
      "schema": { "$ref": "#/entities/RecentActivity" },
      "description": "Stores recent activity logs for a user."
    }
  }
}
